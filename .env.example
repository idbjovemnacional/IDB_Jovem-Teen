# Copie para .env.development (local) e .env.production (build) e preencha.
# Os .env.* reais sao ignorados pelo git (ver .gitignore). NUNCA commite URLs de producao.

# URL base da API FastAPI (sem barra no final).
# Em producao DEVE ser https:// (o cliente axios recusa http em build de producao).
VITE_API_URL=http://localhost:8000

# Keycloak (cliente publico OIDC) — usado quando o login real for plugado.
# Realm e client-id de cliente publico nao sao segredos, mas a URL fica fora do git.
VITE_KEYCLOAK_URL=https://keycloak.exemplo/auth
VITE_KEYCLOAK_REALM=seu-realm
VITE_KEYCLOAK_CLIENT_ID=seu-client-id
